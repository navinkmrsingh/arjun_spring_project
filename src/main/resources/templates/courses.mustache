<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Courses</title>
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
<header>
    <h1>Available Courses</h1>
</header>
<div class="container">
    <table border="1" style="width:100%; border-collapse:collapse;">
        <tr>
            <th>ID</th>
            <th>Course Name</th>
            <th>Code</th>
            <th>Description</th>
            <th>Credits</th>
            <th>Department</th>
            <th>Tutor</th>
        </tr>
        {{#courses}}
        <tr>
            <td>{{courseId}}</td>
            <td>{{courseName}}</td>
            <td>{{courseCode}}</td>
            <td>{{description}}</td>
            <td>{{credits}}</td>
            <td>{{department}}</td>
            <td>{{tutorName}}</td>
        </tr>
        {{/courses}}
    </table>
    <br>
    <a href="/courses/add" class="btn">Add New Course</a>
    <a href="/" class="btn">← Back to Home</a>
</div>
</body>
</html>